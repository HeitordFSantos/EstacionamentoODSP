<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".SaidaActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rootLayoutSaida"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/textViewSaidaTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Veículos no Pátio"
            android:textColor="@color/ondadura_black"
            android:textSize="30sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textViewSaidaSubTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Selecione um veículo para dar saída ou entrar em contato"
            android:textColor="@color/ondadura_gray"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewSaidaTitle" />

        <LinearLayout
            android:id="@+id/linearLayoutCarrosSaida"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewSaidaSubTitle" />

        <Button
            android:id="@+id/buttonVoltarMenu"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp"
            android:text="Voltar"
            android:textColor="@color/ondadura_purple"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/linearLayoutCarrosSaida"
            app:layout_constraintVertical_bias="1.0"
            app:layout_constraintWidth_max="400dp"
            app:strokeColor="@color/ondadura_purple" />

        <!-- Elementos removidos por não serem mais necessários com a nova lógica de cards -->
        <Button android:id="@+id/buttonLista" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" tools:ignore="MissingConstraints" />
        <EditText android:id="@+id/editTextPlacaSaida" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" tools:ignore="MissingConstraints" />
        <Button android:id="@+id/buttonConfirmarSaida" android:visibility="gone" android:layout_width="0dp" android:layout_height="0dp" tools:ignore="MissingConstraints" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
