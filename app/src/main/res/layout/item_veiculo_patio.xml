<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/ondadura_purple"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textViewPlacaCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ABC-1234"
            android:textColor="@color/ondadura_black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewDonoCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Dono: João Silva"
            android:textColor="@color/ondadura_black" />

        <TextView
            android:id="@+id/textViewEntradaCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Entrada: 10/10/2023 14:00"
            android:textColor="@color/ondadura_gray"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonWhatsappCard"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="WhatsApp"
                android:textColor="#25D366"
                android:textSize="12sp"
                app:icon="@android:drawable/stat_notify_chat"
                app:iconTint="#25D366"
                app:strokeColor="#25D366" />

            <Button
                android:id="@+id/buttonSairCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="@color/ondadura_purple"
                android:text="Retirar"
                android:textColor="@color/ondadura_white" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
