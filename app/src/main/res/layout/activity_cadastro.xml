<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        tools:context=".CadastroActivity">

        <TextView
            android:id="@+id/textViewCadastroTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="@string/title_cadastro"
            android:textColor="@color/ondadura_black"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/buttonlistarTodos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/ondadura_purple"
            android:text="@string/button_listar_todos"
            android:textColor="@color/ondadura_black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewCadastroTitle" />

        <EditText
            android:id="@+id/editTextBuscaPlaca"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:autofillHints="Placa"
            android:hint="@string/hint_buscar_placa"
            android:inputType="textCapCharacters"
            app:layout_constraintEnd_toStartOf="@+id/buttonBuscar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/buttonlistarTodos" />

        <Button
            android:id="@+id/buttonBuscar"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginBottom="16dp"
            android:text="@string/button_buscar"
            app:layout_constraintBottom_toBottomOf="@id/editTextBuscaPlaca"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/editTextBuscaPlaca" />

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="?android:attr/listDivider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editTextBuscaPlaca" />

        <LinearLayout
            android:id="@+id/layoutDadosVeiculo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"
            tools:visibility="visible">

            <EditText
                android:id="@+id/editTextNomeEdicao"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="8dp"
                android:hint="@string/nome"
                android:autofillHints="name"
                android:inputType="textPersonName|textCapWords" />

            <EditText
                android:id="@+id/editTextTelefoneEdicao"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="8dp"
                android:hint="@string/telefone"
                android:autofillHints="tel"
                android:inputType="phone" />

            <EditText
                android:id="@+id/editTextModeloEdicao"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:hint="@string/modelo"
                android:autofillHints="modelo"
                android:inputType="textCapWords" />

            <Button
                android:id="@+id/buttonAlterar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/ondadura_purple"
                android:text="@string/button_alterar" />

            <Button
                android:id="@+id/buttonExcluir"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/button_excluir"
                android:textColor="@android:color/holo_red_dark" />
        </LinearLayout>

        <Button
            android:id="@+id/buttonVoltarCadastro"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/button_voltar"
            android:textColor="@color/ondadura_purple"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="@color/ondadura_purple" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>