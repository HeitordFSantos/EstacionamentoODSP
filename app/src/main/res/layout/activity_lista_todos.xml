<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingHorizontal="@dimen/screen_padding_horizontal"
    android:paddingTop="@dimen/screen_padding_vertical"
    tools:context=".ListaTodosActivity">

    <TextView
        android:id="@+id/textViewListaTodosTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_lista_todos"
        android:textSize="@dimen/text_size_title"
        android:textStyle="bold"
        android:textColor="@color/ondadura_black"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Contagem de veículos -->
    <TextView
        android:id="@+id/textViewContagem"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_small"
        android:gravity="center"
        android:text="@string/contagem_veiculos_placeholder"
        android:textColor="@color/ondadura_gray"
        android:textSize="@dimen/text_size_caption"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textViewListaTodosTitle" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_medium"
        android:layout_marginBottom="@dimen/margin_medium"
        app:layout_constraintBottom_toTopOf="@+id/buttonVoltarListaTodos"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textViewContagem">

        <LinearLayout
            android:id="@+id/linearLayoutCarrosTodos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_small" />
    </ScrollView>

    <Button
        android:id="@+id/buttonVoltarListaTodos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/screen_padding_vertical"
        android:backgroundTint="@color/ondadura_purple"
        android:text="@string/button_voltar"
        android:textColor="@color/ondadura_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
